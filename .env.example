# Ollama config.
# Override order: .env < .env.<profile> < shell.

# Ollama server URL. Required — or the official OLLAMA_HOST (OLLAMA_BASE_URL wins).
# Examples:
#   http://localhost:11434     (default local install, OLLAMA_BASE_URL)
#   http://192.168.1.17:11434  (LAN box running ollama)
#   127.0.0.1:11434            (bare host:port via OLLAMA_HOST — http:// is added)
OLLAMA_BASE_URL=

# Note: fetch timeout is the universal PLURNK_FETCH_TIMEOUT (set in
# plurnk-service's env). Local models can be slow; the default
# 600000 (10m) is usually fine.
# Reasoning is the universal PLURNK_PROVIDERS_REASONING_BUDGET; provider
# translates a positive budget into Ollama's `think: true` wire flag.
