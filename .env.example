# Ollama config.
# Override order: .env < .env.<profile> < shell.

# Ollama server URL. Required.
# Examples:
#   http://localhost:11434     (default local install)
#   http://192.168.1.17:11434  (LAN box running ollama)
OLLAMA_BASE_URL=

# Note: fetch timeout is the universal PLURNK_PROVIDER_FETCH_TIMEOUT
# (set in plurnk-service's env). Local models can be slow; the default
# 600000 (10m) is usually fine.
# Reasoning is the universal PLURNK_REASON; provider translates a
# positive budget into Ollama's `think: true` wire flag.
